<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="room_manager_resource_view_list" model="ir.ui.view">
        <field name="name">room.manager.resource.view.list</field>
        <field name="model">room.manager.resource</field>
        <field name="arch" type="xml">
            <list string="Resources">
                <field name="id" optional="hide"/>
                <field name="name"/>
                <field name="type_id"/>
                <field name="allowed_parameter_ids" widget="many2many_tags" readonly="1"/>
                <field name="contains_resource_ids" widget="many2many_tags"/>
                <field name="contained_by_resource_ids" widget="many2many_tags"/>

            </list>
        </field>
    </record>

    <record id="room_manager_resource_view_form" model="ir.ui.view">
        <field name="name">room.manager.resource.view.form</field>
        <field name="model">room.manager.resource</field>
        <field name="arch" type="xml">
            <form string="Resource">
                <field name="id" invisible="1"/>
                <sheet>
                    <group>
                        <group string="General">
                            <field name="name"/>
                            <field name="type_id"/>
                            <field name="allowed_parameter_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Parameters">
                            <field name="allowed_parameter_ids" context="{'resource_id':id}">
                                <list>
                                    <field name="id" optional="hide"/>
                                    <field name="name"/>
                                    <button name="action_graph" type="object" string="Graph" />
                                </list>
                            </field>
                        </page>

                        <page string="Contains Resources">
                            <field name="contains_resource_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="type_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Contained by Resources">
                            <field name="contained_by_resource_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="type_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="room_manager_resource_view_search" model="ir.ui.view">
        <field name="name">room.manager.resource.view.search</field>
        <field name="model">room.manager.resource</field>
        <field name="arch" type="xml">
            <search string="Resources">
                <field name="name"/>
                <field name="type_id"/>
                <group expand="1" string="Group By">
                    <filter string="Resource Type" name="group_by_type" context="{'group_by': 'type_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="room_manager_resource_action" model="ir.actions.act_window">
        <field name="name">Resources</field>
        <field name="res_model">room.manager.resource</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>