<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="room_manager_log_view_list" model="ir.ui.view">
        <field name="name">room.manager.log.view.list</field>
        <field name="model">room.manager.log</field>
        <field name="arch" type="xml">
            <list string="Logs" >
                <field name="create_date" string="Date" readonly="1"/>
                <field name="timestamp"/>
                <field name="direction"/>
                <field name="resource_type_id"/>
                <field name="resource_id"/>
                <field name="parameter_id"/>
                <field name="parameter_value"/>
                <field name="message" optional="hide"/>
<!--                <field name="is_critical" widget="boolean"/>-->
            </list>
        </field>
    </record>

    <record id="room_manager_log_view_form" model="ir.ui.view">
        <field name="name">room.manager.log.view.form</field>
        <field name="model">room.manager.log</field>
        <field name="arch" type="xml">
            <form string="Log Entry">
                <sheet>
                    <group>
                        <group string="Event">
                            <field name="timestamp"/>
                            <field name="direction"/>
                            <field name="resource_type_id"/>
                            <field name="resource_id"/>
                        </group>
                        <group string="Parameter">
                            <field name="parameter_id"/>
                            <field name="parameter_value"/>
                            <field name="message"/>
<!--                            <field name="is_critical" widget="boolean"/>-->
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="room_manager_log_view_graph" model="ir.ui.view">
        <field name="name">room.manager.log.view.graph</field>
        <field name="model">room.manager.log</field>
        <field name="arch" type="xml">
            <graph string="Log Entries" type="line">
                <!-- X-axis: time -->
                <field name="timestamp" interval="day"/>

                <!-- Y-axis: value -->
                <field name="parameter_value_numeric" type="measure"/>
            </graph>
        </field>
    </record>


    <record id="room_manager_log_view_search" model="ir.ui.view">
        <field name="name">room.manager.log.view.search</field>
        <field name="model">room.manager.log</field>
        <field name="arch" type="xml">
            <search string="Logs">
                <field name="resource_id"/>
                <field name="resource_type_id"/>
                <field name="parameter_id"/>
                <filter string="Incoming" name="filter_incoming"
                        domain="[('direction', '=', 'incoming')]"/>
                <filter string="Outgoing" name="filter_outgoing"
                        domain="[('direction', '=', 'outgoing')]"/>
                <separator/>
<!--                <filter string="Critical" name="filter_critical"-->
<!--                        domain="[('is_critical', '=', True)]"/>-->
                <group expand="1" string="Group By">
                    <filter string="Direction" name="group_by_direction"
                            context="{'group_by': 'direction'}"/>
                    <filter string="Resource Type" name="group_by_resource_type"
                            context="{'group_by': 'resource_type_id'}"/>
                    <filter string="Parameter" name="group_by_parameter"
                            context="{'group_by': 'parameter_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="room_manager_log_action" model="ir.actions.act_window">
        <field name="name">Logs</field>
        <field name="res_model">room.manager.log</field>
        <field name="view_mode">list,form,graph</field>
    </record>

</odoo>