<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="room_manager_resource_type_view_list" model="ir.ui.view">
        <field name="name">room.manager.resource.type.view.list</field>
        <field name="model">room.manager.resource.type</field>
        <field name="arch" type="xml">
            <list string="Resource Types">
                <field name="name"/>
                <field name="allowed_parameter_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="room_manager_resource_type_view_form" model="ir.ui.view">
        <field name="name">room.manager.resource.type.view.form</field>
        <field name="model">room.manager.resource.type</field>
        <field name="arch" type="xml">
            <form string="Resource Type">
                <sheet>
                    <group>
                        <field name="id" optional="hide"/>
                        <field name="name"/>
                        <field name="allowed_parameter_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="room_manager_resource_type_view_search" model="ir.ui.view">
        <field name="name">room.manager.resource.type.view.search</field>
        <field name="model">room.manager.resource.type</field>
        <field name="arch" type="xml">
            <search string="Resource Types">
                <field name="name"/>
                <field name="allowed_parameter_ids" widget="many2many_tags"/>
            </search>
        </field>
    </record>

    <record id="room_manager_resource_type_action" model="ir.actions.act_window">
        <field name="name">Resource Types</field>
        <field name="res_model">room.manager.resource.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>